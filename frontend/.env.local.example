NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-32-char-secret

# Supabase Auth (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Copy JWT Secret from Supabase → Settings → API → JWT Settings
# into root .env as SUPABASE_JWT_SECRET (backend validates tokens)

# Dev mode (local without Supabase)
NEXT_PUBLIC_DEV_AUTH=true
NEXT_PUBLIC_DEV_EMAIL=dev@jobhunter.local
